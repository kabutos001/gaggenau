# Database
# Use port 5435 when connecting from host to Docker PostgreSQL
# Use port 5432 when running inside Docker (container-to-container)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5435/template_db

# Server
PORT=3000

# CORS
CORS_ORIGIN=http://localhost:5173

# Environment
APP_ENV=development

# Gemini — powers the cooking assistant (voice → oven program).
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key
