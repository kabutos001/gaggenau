# Development Dockerfile for FastAPI backend with hot reload
FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app/backend

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Copy dependency files
COPY backend/pyproject.toml backend/uv.lock* ./

# Install dependencies (including dev dependencies)
RUN uv sync --frozen || uv sync

# Copy application code (in dev, this will be overridden by volume mount)
COPY backend/app ./app
COPY backend/alembic ./alembic
COPY backend/alembic.ini ./alembic.ini

EXPOSE 3000

# Run migrations and start server with hot reload
CMD ["sh", "-c", "uv run alembic upgrade head && uv run uvicorn app.main:app --host 0.0.0.0 --port 3000 --reload"]

